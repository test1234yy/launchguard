# LaunchGuard environment variables
# Copy this file to .env.local and fill in values. Every variable is optional:
# the app, the demo scan, GitHub scanning and ZIP scanning all work without any keys.

# Optional. Enables AI-generated fix plans via the OpenAI API.
# When absent, LaunchGuard produces a deterministic fix plan instead.
OPENAI_API_KEY=

# Optional. OpenAI model used for fix plans. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Optional. GitHub token used only to raise the anonymous API rate limit when
# resolving repository metadata. Public repositories work without it.
GITHUB_TOKEN=
