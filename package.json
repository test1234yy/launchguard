{
  "name": "launchguard",
  "version": "1.1.0",
  "private": true,
  "description": "Deployment readiness scanner for Next.js and Node.js projects",
  "license": "MIT",
  "homepage": "https://github.com/test1234yy/launchguard",
  "repository": {
    "type": "git",
    "url": "https://github.com/test1234yy/launchguard.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
